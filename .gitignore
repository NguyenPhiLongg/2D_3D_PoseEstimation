# Use Git LFS or external storage if needed.
# =========================================================

*.pt
*.pth
*.bin
*.onnx
*.engine

# =========================================================
# YOLO pretrained weights
# =========================================================

yolov8*.pt

# =========================================================
# PoseFormerV2 external repository
# Ignore if cloned inside this project.
# =========================================================

phase2_3d_upgrade/poseformerv2_repo/

