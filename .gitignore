data/1_raw_videos/
*.mp4
*.avi
*.mov
*.mkv
*.webm

# =========================================================
# Extracted pose data
# These files can be regenerated from raw videos.
# =========================================================

data/2_extracted_2d/
data/3_extracted_3d/
data/4_normalized_3d/

# Keep the folder structure if .gitkeep files are used
!data/2_extracted_2d/.gitkeep
!data/3_extracted_3d/.gitkeep
!data/4_normalized_3d/.gitkeep

# =========================================================
# Master dataset CSV
# This file can be large and may contain generated pose data.
# =========================================================

data/master_dataset.csv

