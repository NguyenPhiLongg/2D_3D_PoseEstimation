# Training checkpoints
# =========================================================

phase1_2d_baseline/checkpoints/
phase2_3d_upgrade/checkpoints/

# Keep folder structure if needed
!phase1_2d_baseline/checkpoints/.gitkeep
!phase2_3d_upgrade/checkpoints/.gitkeep

# =========================================================
# Large demo outputs
# =========================================================

phase2_3d_upgrade/outputs/demo_3d_frames/
phase2_3d_upgrade/outputs/demo_3d_videos/
phase2_3d_upgrade/outputs/demo_3d_csv/

# =========================================================
# Keep lightweight result files
# JSON, CSV comparison, and dashboard HTML are allowed.
# =========================================================

!phase2_3d_upgrade/outputs/training_3d/
!phase2_3d_upgrade/outputs/training_3d/*.json

!phase2_3d_upgrade/outputs/training_fusion_2d3d/
!phase2_3d_upgrade/outputs/training_fusion_2d3d/*.json

!phase2_3d_upgrade/outputs/comparison_results/
!phase2_3d_upgrade/outputs/comparison_results/*.csv

!phase2_3d_upgrade/outputs/model_comparison_dashboard.html

!phase1_2d_baseline/outputs/
!phase1_2d_baseline/outputs/training_2d/
!phase1_2d_baseline/outputs/training_2d/*.json

